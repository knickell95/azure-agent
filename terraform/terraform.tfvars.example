# Copy to terraform.tfvars and adjust values before running terraform apply.

location            = "westus2"
resource_group_name = "rg-azure-agent-ai"
hub_name            = "azure-agent-hub"
project_name        = "azure-agent-project"
openai_account_name = "oai-azure-agent"

# Model — see https://learn.microsoft.com/azure/ai-services/openai/concepts/models
# for available models and versions per region. Leave model_version empty to let
# Azure select the default version, or check available versions with:
#   az cognitiveservices account list-models --location westus2 --query "[?name=='gpt-5.2']"
model_name    = "gpt-5.2"
model_version = ""

# Capacity in thousands of tokens per minute (GlobalStandard is pay-as-you-go).
model_sku      = "GlobalStandard"
model_capacity = 10

tags = {
  application = "azure-agent"
  managed-by  = "terraform"
}
