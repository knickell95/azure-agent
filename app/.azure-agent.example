# Copy this file to .azure-agent and fill in your values.
# DefaultAzureCredential will also pick up az CLI login, managed identity, etc.
# When running in Docker, az CLI login is supported via the ~/.azure volume mount
# in docker-compose.yml. A service principal can also be used instead.

# Optional: explicitly set a service principal
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=

# Optional: use managed identity instead of az CLI or service principal
# For system-assigned managed identity:
# AZURE_USE_MANAGED_IDENTITY=true
# For user-assigned managed identity (specify the client ID of the identity):
# AZURE_MANAGED_IDENTITY_CLIENT_ID=

# Optional: set a default subscription so the agent doesn't have to ask every time
# AZURE_DEFAULT_SUBSCRIPTION_ID=

# Anthropic API key (used when AI_PROVIDER=anthropic, which is the default)
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Azure AI Foundry / Azure OpenAI (set AI_PROVIDER=openai to use these)
# Run `terraform output -raw app_env_vars` after deploying the Terraform
# config in /terraform to get pre-filled values for the block below.
# ---------------------------------------------------------------------------
# AI_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://<account>.openai.azure.com/
# OPENAI_API_VERSION=2024-10-21
# OPENAI_DEPLOYMENT_NAME=gpt-4o
